# DeepSeek V4 — 在 https://platform.deepseek.com/api_keys 创建密钥后填入
DEEPSEEK_API_KEY=

# 模型：deepseek-v4-flash（默认，性价比高）| deepseek-v4-pro（更强）
YSCAPE_MODEL_NAME=deepseek-v4-flash
YSCAPE_MODEL_PROVIDER=deepseek
YSCAPE_DEEPSEEK_API_BASE=https://api.deepseek.com

# 推理模式（对应旧版 deepseek-reasoner 行为）
YSCAPE_DEEPSEEK_THINKING=false

# 关闭 Demo 后使用 DeepSeek V4 真实规划与综合（需已配置 DEEPSEEK_API_KEY）
YSCAPE_DEMO_MODE=false

# LLM 单次请求超时（秒）
YSCAPE_LLM_TIMEOUT_SECONDS=90
